config.stopBubbling = true
lombok.accessors.fluent = true
lombok.equalsAndHashCode.callSuper = skip
lombok.toString.callSuper = skip
lombok.addLombokGeneratedAnnotation = true
# Propagate nullness annotations from fields to Lombok-generated
# constructor parameters and accessor signatures so SpotBugs nullness
# analysis flows correctly through the generated code.
lombok.copyableAnnotations += edu.umd.cs.findbugs.annotations.Nullable
lombok.copyableAnnotations += edu.umd.cs.findbugs.annotations.NonNull
lombok.copyableAnnotations += javax.annotation.Nullable
lombok.copyableAnnotations += javax.annotation.Nonnull
