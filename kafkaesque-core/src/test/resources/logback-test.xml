<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Set default log level to INFO for tests -->
    <root level="INFO">
        <appender-ref ref="STDOUT" />
    </root>

    <!-- Set Kafkaesque components to INFO for better test visibility -->
    <logger name="eu.kafkaesque" level="INFO" />
</configuration>
